{
  "name": "proyek-hardhat-anda",
  "version": "1.0.0",
  "scripts": {
    "node": "npx hardhat node",
    "deploy:local": "npx hardhat run scripts/deployTokenLocal.ts --network localhost",
    "frontend:start": "cd ../my-local-token-ui && npm start",
    "_deploy-then-start": "npm run deploy:local && npm run frontend:start",
    "dev": "npm-run-all --parallel node \"_deploy-then-start\""
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^20.12.12",
    "concurrently": "^8.2.2",
    "hardhat": "^2.22.5",
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.3.0",
    "framer-motion": "^12.7.4",
    "react-icons": "^5.5.0"
  }
}
